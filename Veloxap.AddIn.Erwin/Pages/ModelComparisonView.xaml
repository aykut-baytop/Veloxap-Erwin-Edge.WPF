<UserControl x:Class="Veloxap.AddIn.Erwin.Pages.ModelComparisonView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="540"
             d:DesignWidth="920">

    <UserControl.Resources>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="128"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.78"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Background" Value="#D1D5DB"/>
                                <Setter Property="Foreground" Value="#6B7280"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PanelTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#111827"/>
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="True"/>
            <Setter Property="Padding" Value="0,2"/>
            <Setter Property="Margin" Value="0,1"/>
        </Style>

        <HierarchicalDataTemplate x:Key="DiffNodeTemplate"
                                  ItemsSource="{Binding Children}">
            <Border Padding="3"
                    CornerRadius="6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Width="24"
                            Height="24"
                            CornerRadius="6"
                            Background="{Binding IconBackground}"
                            VerticalAlignment="Top"
                            Margin="0,1,8,0">
                        <TextBlock Text="{Binding Icon}"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="12"
                                   Foreground="{Binding IconBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{Binding Title}"
                                   FontWeight="{Binding TitleWeight}"
                                   Foreground="{Binding TitleBrush}"
                                   TextWrapping="Wrap"/>

                        <TextBlock Text="{Binding Description}"
                                   Visibility="{Binding DescriptionVisibility}"
                                   Foreground="#6B7280"
                                   FontSize="11"
                                   Margin="0,2,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <Border Grid.Column="2"
                            Visibility="{Binding BadgeVisibility}"
                            Background="{Binding BadgeBackground}"
                            CornerRadius="6"
                            Padding="7,2"
                            Margin="8,1,0,0"
                            VerticalAlignment="Top">
                        <TextBlock Text="{Binding BadgeText}"
                                   Foreground="{Binding BadgeBrush}"
                                   FontSize="10"
                                   FontWeight="SemiBold"/>
                    </Border>
                </Grid>
            </Border>
        </HierarchicalDataTemplate>
    </UserControl.Resources>

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Model KarÅŸÄ±laÅŸtÄ±rma"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="#111827"/>
                <TextBlock x:Name="txtModelPair"
                           Text="DEV / INT"
                           Margin="0,5,0,0"
                           Foreground="#6B7280"
                           FontSize="13"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>

            <Button x:Name="btnCompare"
                    Grid.Column="2"
                    Style="{StaticResource ActionButtonStyle}"
                    Click="BtnCompare_Click">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE8EE;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="13"
                               Margin="0,0,7,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="KarÅŸÄ±laÅŸtÄ±r"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <Border Grid.Row="2"
                Background="#F8FAFC"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="0.8*"/>
                    <ColumnDefinition Width="1.3*"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Sol Model"
                               Style="{StaticResource MutedTextStyle}"/>
                    <TextBlock x:Name="txtLeftModelName"
                               Margin="0,4,0,0"
                               FontWeight="SemiBold"
                               Foreground="#111827"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Margin="18,0,0,0">
                    <TextBlock Text="SaÄŸ Model"
                               Style="{StaticResource MutedTextStyle}"/>
                    <TextBlock x:Name="txtRightModelName"
                               Margin="0,4,0,0"
                               FontWeight="SemiBold"
                               Foreground="#111827"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Margin="18,0,0,0">
                    <TextBlock Text="Toplam Fark"
                               Style="{StaticResource MutedTextStyle}"/>
                    <TextBlock x:Name="txtTotalDiffCount"
                               Text="0"
                               Margin="0,2,0,0"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#0F766E"/>
                </StackPanel>

                <StackPanel Grid.Column="3"
                            Margin="18,0,0,0">
                    <TextBlock Text="Durum"
                               Style="{StaticResource MutedTextStyle}"/>
                    <TextBlock x:Name="txtStatus"
                               Text="HazÄ±r"
                               Margin="0,4,0,0"
                               Foreground="#374151"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Background="#FFFFFF"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12">
                <DockPanel>
                    <Grid DockPanel.Dock="Top"
                          Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="txtRightToLeftTitle"
                                           Text="INT -> DEV"
                                           Style="{StaticResource PanelTitleStyle}"/>
                                <Border Background="#CCFBF1"
                                        CornerRadius="6"
                                        Padding="7,2"
                                        Margin="8,0,0,0">
                                    <TextBlock x:Name="txtRightToLeftCount"
                                               Text="0"
                                               Foreground="#0F766E"
                                               FontSize="10"
                                               FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>
                            <TextBlock x:Name="txtRightToLeftSubtitle"
                                       Text="DEV tarafÄ±na uygulanacak farklar"
                                       Style="{StaticResource MutedTextStyle}"
                                       Margin="0,3,0,0"/>
                        </StackPanel>

                        <Button x:Name="btnApplyRightToLeft"
                                Grid.Column="1"
                                Style="{StaticResource ActionButtonStyle}"
                                Background="#0F766E"
                                Click="BtnApplyRightToLeft_Click"
                                IsEnabled="False">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE72A;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="12"
                                           Margin="0,0,7,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="txtApplyRightToLeftButton"
                                           Text="INT -> DEV Aktar"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Grid>
                        <TreeView x:Name="treeRightToLeft"
                                  ItemTemplate="{StaticResource DiffNodeTemplate}"
                                  BorderThickness="0"
                                  Background="#FFFFFF"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>

                        <Border x:Name="emptyRightToLeft"
                                Background="#FFFFFF"
                                Visibility="Visible">
                            <TextBlock Text="Fark yok"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="#6B7280"/>
                        </Border>
                    </Grid>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="10"
                          HorizontalAlignment="Stretch"
                          Background="Transparent"/>

            <Border Grid.Column="2"
                    Background="#FFFFFF"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12">
                <DockPanel>
                    <Grid DockPanel.Dock="Top"
                          Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="txtLeftToRightTitle"
                                           Text="DEV -> INT"
                                           Style="{StaticResource PanelTitleStyle}"/>
                                <Border Background="#FEF3C7"
                                        CornerRadius="6"
                                        Padding="7,2"
                                        Margin="8,0,0,0">
                                    <TextBlock x:Name="txtLeftToRightCount"
                                               Text="0"
                                               Foreground="#92400E"
                                               FontSize="10"
                                               FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>
                            <TextBlock x:Name="txtLeftToRightSubtitle"
                                       Text="INT tarafÄ±na uygulanacak farklar"
                                       Style="{StaticResource MutedTextStyle}"
                                       Margin="0,3,0,0"/>
                        </StackPanel>

                        <Button x:Name="btnApplyLeftToRight"
                                Grid.Column="1"
                                Style="{StaticResource ActionButtonStyle}"
                                Background="#B45309"
                                Click="BtnApplyLeftToRight_Click"
                                IsEnabled="False">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE72B;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="12"
                                           Margin="0,0,7,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="txtApplyLeftToRightButton"
                                           Text="DEV -> INT Aktar"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Grid>
                        <TreeView x:Name="treeLeftToRight"
                                  ItemTemplate="{StaticResource DiffNodeTemplate}"
                                  BorderThickness="0"
                                  Background="#FFFFFF"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>

                        <Border x:Name="emptyLeftToRight"
                                Background="#FFFFFF"
                                Visibility="Visible">
                            <TextBlock Text="Fark yok"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="#6B7280"/>
                        </Border>
                    </Grid>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
