<UserControl x:Class="Veloxap.AddIn.Erwin.Pages.ModelInfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="540"
             d:DesignWidth="920">

    <UserControl.Resources>
        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="SummaryLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="SummaryValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="LockBadgeStyle" TargetType="Border">
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Background" Value="#ECFDF5"/>
            <Setter Property="BorderBrush" Value="#A7F3D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="0,5,0,0"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsLocked}" Value="True">
                    <Setter Property="Background" Value="#FFF1F2"/>
                    <Setter Property="BorderBrush" Value="#FFE4E6"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LockBadgeTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#047857"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsLocked}" Value="True">
                    <Setter Property="Foreground" Value="#BE123C"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

    </UserControl.Resources>

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="#F8FAFC"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12"
                Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="MODEL LOCK DURUMU"
                               Style="{StaticResource SummaryLabelStyle}"/>

                    <Border Style="{StaticResource LockBadgeStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72E;"
                                       FontFamily="Segoe MDL2 Assets"
                                       Style="{StaticResource LockBadgeTextStyle}"
                                       FontSize="12"
                                       Margin="0,0,6,0"/>

                            <TextBlock Text="{Binding LockStatusText}"
                                       Style="{StaticResource LockBadgeTextStyle}"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="{Binding LockDetailText}"
                               Style="{StaticResource MutedTextStyle}"
                               TextWrapping="Wrap"
                               Margin="0,3,12,0"/>

                    <Button x:Name="btnUnlockCatalog"
                            Content="Lock Kaldir"
                            Height="30"
                            Width="110"
                            HorizontalAlignment="Left"
                            Margin="0,8,0,0"
                            Background="#DC2626"
                            Foreground="White"
                            BorderBrush="#B91C1C"
                            BorderThickness="1"
                            FontWeight="SemiBold"
                            Click="BtnUnlockCatalog_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Setter Property="IsEnabled" Value="True"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CanUnlockCatalog}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsUnlockingCatalog}" Value="True">
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <TextBlock Text="{Binding UnlockCatalogMessage}"
                               Style="{StaticResource MutedTextStyle}"
                               TextWrapping="Wrap"
                               Margin="0,4,12,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowApprovalStatus}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock Text="ONAY DURUMU"
                               Style="{StaticResource SummaryLabelStyle}"/>

                    <TextBlock Text="{Binding ApprovalStatusText}"
                               Style="{StaticResource SummaryValueStyle}"
                               Margin="0,4,0,0"/>

                    <ItemsControl ItemsSource="{Binding ApprovalSteps}"
                                  Margin="0,6,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White"
                                        BorderBrush="#E5E7EB"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="8,4"
                                        Margin="0,0,6,6">
                                    <TextBlock Text="{Binding StepText}"
                                               Foreground="#374151"
                                               FontSize="12"
                                               TextWrapping="Wrap"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl x:Name="tabModelSections"
                    Grid.Row="1"
                    Background="White"
                    BorderThickness="0"
                    Padding="0">
        <TabItem x:Name="tabTableUdps"
                 Header="Tablo UDP'leri">
            <ContentControl x:Name="tableUdpContent"
                            Margin="0,12,0,0"/>
        </TabItem>
        </TabControl>
    </Grid>
</UserControl>
