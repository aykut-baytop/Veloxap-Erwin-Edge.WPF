<UserControl x:Class="Veloxap.AddIn.Erwin.Pages.ModelValidationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:pages="clr-namespace:Veloxap.AddIn.Erwin.Pages"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="132"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Background" Value="#D1D5DB"/>
                                <Setter Property="Foreground" Value="#6B7280"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="6"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="150"/>
            </Grid.ColumnDefinitions>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Kaynak Versiyon" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox x:Name="cmbSourceVersion"
                                  Height="34"
                                  MinWidth="150"
                                  IsEnabled="False"
                                  DisplayMemberPath="DisplayName"
                                  SelectionChanged="VersionSelection_Changed"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Hedef Versiyon" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox x:Name="cmbTargetVersion"
                                  Height="34"
                                  MinWidth="150"
                                  IsEnabled="False"
                                  DisplayMemberPath="DisplayName"
                                  SelectionChanged="VersionSelection_Changed"/>
                    </StackPanel>
                </Grid>
            </Grid>

            <StackPanel Grid.Column="2"
                        VerticalAlignment="Bottom">
                <Button x:Name="btnRunValidation"
                        Content="Validasyon Testi"
                        Style="{StaticResource ActionButtonStyle}"
                        Click="BtnRunValidation_Click"/>

                <Button x:Name="btnSendApproval"
                        Content="Onaya Gonder"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="#059669"
                        Click="BtnSendApproval_Click"
                        IsEnabled="False"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="2"
                Background="#F9FAFB"
                BorderBrush="#E5E7EB"
                BorderThickness="0,1,0,1"
                Padding="8,5">
            <TextBlock x:Name="txtStatusMessage"
                       FontSize="12"
                       Foreground="#4B5563"
                       TextWrapping="Wrap"
                       TextTrimming="CharacterEllipsis"
                       MaxHeight="38"/>
        </Border>

        <TabControl x:Name="validationTabs"
                    Grid.Row="4"
                    Background="Transparent"
                    BorderBrush="#E5E7EB">
            <TabItem x:Name="tabAlterDdl" Header="Alter DDL ve UDP Guncelleme">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*" MinWidth="220"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="2*" MinWidth="190"/>
                    </Grid.ColumnDefinitions>

                    <Border BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            Background="#FAFAFA">
                        <DockPanel>
                            <TextBlock Text="DDL"
                                       DockPanel.Dock="Top"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#374151"
                                       Margin="10,8,10,4"/>
                            <TextBox x:Name="txtAlterDdl"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     AcceptsReturn="True"
                                     AcceptsTab="True"
                                     IsReadOnly="True"
                                     TextWrapping="NoWrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     BorderThickness="0"
                                     Background="#FAFAFA"
                                     Padding="10"/>
                        </DockPanel>
                    </Border>

                    <GridSplitter Grid.Column="1"
                                  Width="6"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  Background="#E5E7EB"
                                  ShowsPreview="True"/>

                    <Border Grid.Column="2"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            Background="#FFFFFF">
                        <DockPanel>
                            <TextBlock Text="UDP Guncelleme Sonucu"
                                       DockPanel.Dock="Top"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#374151"
                                       Margin="10,8,10,4"/>

                            <Border x:Name="tableUdpResultPanel"
                                    Background="#F8FAFC"
                                    BorderBrush="#E5E7EB"
                                    BorderThickness="1,0,0,0"
                                    Padding="10"
                                    Visibility="Collapsed">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock x:Name="txtTableUdpResultStatus"
                                               FontSize="12"
                                               Foreground="#4B5563"
                                               TextWrapping="Wrap"/>

                                    <ScrollViewer Grid.Row="2"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <ItemsControl x:Name="tableUdpResultItems">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="#E5E7EB"
                                                            BorderThickness="1"
                                                            Background="White"
                                                            Padding="8,6"
                                                            Margin="0,0,0,8"
                                                            ToolTip="{Binding DetailText}">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Name}"
                                                                       FontSize="12"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="#374151"
                                                                       TextWrapping="Wrap"/>
                                                            <TextBlock Text="{Binding SummaryText}"
                                                                       Margin="0,3,0,0"
                                                                       FontSize="12"
                                                                       Foreground="#6B7280"
                                                                       TextWrapping="Wrap"/>
                                                            <ItemsControl ItemsSource="{Binding Messages}"
                                                                          Margin="0,6,0,0">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <TextBlock Text="{Binding}"
                                                                                   FontSize="11"
                                                                                   Foreground="#4B5563"
                                                                                   TextWrapping="Wrap"
                                                                                   Margin="0,0,0,4"/>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem x:Name="tabValidationRules" Header="Validasyon Kurallari">
                <pages:ValidationRulesView x:Name="validationRulesView"/>
            </TabItem>

            <TabItem x:Name="tabValidationResults" Header="Validasyon Sonuclari">
                <TextBox x:Name="txtValidationResults"
                         FontFamily="Consolas"
                         FontSize="12"
                         AcceptsReturn="True"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         BorderThickness="1"
                         BorderBrush="#E5E7EB"
                         Background="#FAFAFA"
                         Padding="10"/>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
