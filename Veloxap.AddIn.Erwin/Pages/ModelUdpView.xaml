<UserControl x:Class="Veloxap.AddIn.Erwin.Pages.ModelUdpView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:Veloxap.AddIn.Erwin.Pages"
             mc:Ignorable="d"
             d:DesignHeight="540"
             d:DesignWidth="920">

    <UserControl.Resources>
        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="SummaryValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>

        <Style x:Key="UdpTreeItemStyle" TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="VirtualizingStackPanel.IsVirtualizing" Value="True"/>
            <Setter Property="VirtualizingStackPanel.VirtualizationMode" Value="Recycling"/>
            <EventSetter Event="Loaded" Handler="TreeUdpItem_Loaded"/>
            <EventSetter Event="Expanded" Handler="TreeUdpItem_Expanded"/>
        </Style>

        <HierarchicalDataTemplate DataType="{x:Type local:UdpTreeNode}"
                                  ItemsSource="{Binding Children}">
            <TextBlock Text="{Binding Title}"
                       Margin="{Binding IndentMargin}"
                       MinHeight="28"
                       VerticalAlignment="Center"
                       FontWeight="{Binding FontWeight}"
                       Foreground="{Binding Foreground}"
                       TextTrimming="CharacterEllipsis"/>
        </HierarchicalDataTemplate>
    </UserControl.Resources>

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="260"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Tablo UDP'leri"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="#111827"
                       VerticalAlignment="Center"/>

            <StackPanel Grid.Column="1">
                <TextBlock Text="Arama"
                           Style="{StaticResource MutedTextStyle}"
                           Margin="0,0,0,4"/>
                <TextBox x:Name="txtSearch"
                         Height="34"
                         Padding="10,7"
                         VerticalContentAlignment="Center"
                         BorderBrush="#CBD5E1"
                         BorderThickness="1"
                         Background="White"
                         Foreground="#111827"
                         TextChanged="TxtSearch_TextChanged"
                         ToolTip="En az 3 karakterle tablo, UDP veya deger ara"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="2"
                Background="#F8FAFC"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1.4*"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Tablo Sayisi"
                               Style="{StaticResource MutedTextStyle}"/>
                    <TextBlock x:Name="txtTableCount"
                               Text="0"
                               Style="{StaticResource SummaryValueStyle}"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Margin="18,0,0,0">
                    <TextBlock Text="UDP Sayisi"
                               Style="{StaticResource MutedTextStyle}"/>
                    <TextBlock x:Name="txtUdpCount"
                               Text="0"
                               Style="{StaticResource SummaryValueStyle}"
                               Foreground="#0F766E"/>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Margin="18,0,0,0">
                    <TextBlock Text="Listelenen"
                               Style="{StaticResource MutedTextStyle}"/>
                    <TextBlock x:Name="txtVisibleCount"
                               Text="0"
                               Style="{StaticResource SummaryValueStyle}"
                               Foreground="#2563EB"/>
                </StackPanel>

                <StackPanel Grid.Column="3"
                            Margin="18,0,0,0">
                    <TextBlock Text="Durum"
                               Style="{StaticResource MutedTextStyle}"/>
                    <TextBlock x:Name="txtStatus"
                               Text="Hazir"
                               Margin="0,4,0,0"
                               Foreground="#374151"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="4"
                Background="White">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Background="#F9FAFB"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12">
                    <DockPanel>
                        <TextBlock Text="Tablolar"
                                   DockPanel.Dock="Top"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   Foreground="#374151"
                                   Margin="0,0,0,12"/>

                        <TreeView x:Name="treeUdp"
                                  BorderThickness="0"
                                  Background="Transparent"
                                  ItemContainerStyle="{StaticResource UdpTreeItemStyle}"
                                  SelectedItemChanged="TreeUdp_SelectedItemChanged"
                                  VirtualizingStackPanel.IsVirtualizing="True"
                                  VirtualizingStackPanel.VirtualizationMode="Recycling"
                                  ScrollViewer.CanContentScroll="True"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                    </DockPanel>
                </Border>

                <Border Grid.Column="2"
                        Background="#F9FAFB"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12">
                    <DockPanel>
                        <TextBlock x:Name="txtDetailTitle"
                                   Text="UDP Detaylari"
                                   DockPanel.Dock="Top"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   Foreground="#374151"
                                   Margin="0,0,0,12"/>

                        <DataGrid x:Name="gridUdpDetails"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="None"
                                  RowHeight="36"
                                  ColumnHeaderHeight="38"
                                  EnableRowVirtualization="True"
                                  EnableColumnVirtualization="True"
                                  BorderThickness="0"
                                  Background="White"
                                  AlternatingRowBackground="#F3F4F6">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Property"
                                                    Binding="{Binding Property}"
                                                    Width="180"/>
                                <DataGridTextColumn Header="Value"
                                                    Binding="{Binding Value}"
                                                    Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>

                <Border x:Name="emptyState"
                        Grid.ColumnSpan="3"
                        Background="#F9FAFB"
                        Visibility="Collapsed">
                    <TextBlock x:Name="txtEmpty"
                               Text="Secili model tablolarinda UDP bulunamadi."
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#6B7280"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
