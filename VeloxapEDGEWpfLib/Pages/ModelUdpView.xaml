<UserControl x:Class="VeloxapEDGEWpfLib.Pages.ModelUdpView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="540"
             d:DesignWidth="920">

    <UserControl.Resources>
        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="SummaryValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="164"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="#0F766E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.78"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Background" Value="#D1D5DB"/>
                                <Setter Property="Foreground" Value="#6B7280"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Tablo UDP'leri"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="#111827"/>
                <TextBlock x:Name="txtModelName"
                           Text="Secili model"
                           Margin="0,6,0,0"
                           Foreground="#6B7280"
                           FontSize="13"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>

            <Button x:Name="btnCalculateSecurity"
                    Grid.Column="1"
                    Style="{StaticResource ActionButtonStyle}"
                    Click="BtnCalculateSecurity_Click"
                    ToolTip="Tablo UDP Veri_Degeri alanlarini hesapla">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE9D2;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="13"
                               Margin="0,0,7,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="Veri Degeri Hesapla"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button x:Name="btnCalculateBankRelative"
                    Grid.Column="3"
                    Style="{StaticResource ActionButtonStyle}"
                    Background="#2563EB"
                    Click="BtnCalculateBankRelative_Click"
                    ToolTip="Tablo UDP Banka_Gorece_Degeri alanlarini hesapla">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE8EC;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="13"
                               Margin="0,0,7,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="Banka Gorece Hesapla"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button x:Name="btnCalculateSecurityClass"
                    Grid.Column="5"
                    Style="{StaticResource ActionButtonStyle}"
                    Background="#B45309"
                    Click="BtnCalculateSecurityClass_Click"
                    ToolTip="Tablo UDP Guvenlik_Sinifi_Degeri alanlarini hesapla">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE72E;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="13"
                               Margin="0,0,7,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="Guvenlik Sinifi Hesapla"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <TextBox x:Name="txtSearch"
                     Grid.Column="7"
                     Height="34"
                     Padding="10,7"
                     VerticalContentAlignment="Center"
                     BorderBrush="#CBD5E1"
                     BorderThickness="1"
                     Background="White"
                     Foreground="#111827"
                     TextChanged="TxtSearch_TextChanged"
                     ToolTip="Tablo, kolon, UDP veya deger ara"/>
        </Grid>

        <Border Grid.Row="2"
                Background="#F8FAFC"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1.4*"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Tablo Sayisi"
                               Style="{StaticResource MutedTextStyle}"/>
                    <TextBlock x:Name="txtTableCount"
                               Text="0"
                               Style="{StaticResource SummaryValueStyle}"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Margin="18,0,0,0">
                    <TextBlock Text="UDP Sayisi"
                               Style="{StaticResource MutedTextStyle}"/>
                    <TextBlock x:Name="txtUdpCount"
                               Text="0"
                               Style="{StaticResource SummaryValueStyle}"
                               Foreground="#0F766E"/>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Margin="18,0,0,0">
                    <TextBlock Text="Listelenen"
                               Style="{StaticResource MutedTextStyle}"/>
                    <TextBlock x:Name="txtVisibleCount"
                               Text="0"
                               Style="{StaticResource SummaryValueStyle}"
                               Foreground="#2563EB"/>
                </StackPanel>

                <StackPanel Grid.Column="3"
                            Margin="18,0,0,0">
                    <TextBlock Text="Durum"
                               Style="{StaticResource MutedTextStyle}"/>
                    <TextBlock x:Name="txtStatus"
                               Text="Hazir"
                               Margin="0,4,0,0"
                               Foreground="#374151"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="4"
                Background="#F9FAFB"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12">
            <Grid>
                <DataGrid x:Name="gridUdp"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          RowHeight="34"
                          ColumnHeaderHeight="38"
                          BorderThickness="0"
                          Background="White"
                          AlternatingRowBackground="#F3F4F6">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Tablo"
                                            Binding="{Binding TableName}"
                                            Width="1.1*"/>

                        <DataGridTextColumn Header="Nesne"
                                            Binding="{Binding ObjectType}"
                                            Width="80"/>

                        <DataGridTextColumn Header="Kolon"
                                            Binding="{Binding ColumnName}"
                                            Width="1.0*"/>

                        <DataGridTextColumn Header="UDP"
                                            Binding="{Binding UdpName}"
                                            Width="1.2*"/>

                        <DataGridTextColumn Header="Deger"
                                            Binding="{Binding Value}"
                                            Width="1.0*"/>

                        <DataGridTextColumn Header="As String"
                                            Binding="{Binding AsString}"
                                            Width="1.0*"/>

                        <DataGridTextColumn Header="Tip"
                                            Binding="{Binding DataType}"
                                            Width="90"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Border x:Name="emptyState"
                        Background="#F9FAFB"
                        Visibility="Collapsed">
                    <TextBlock x:Name="txtEmpty"
                               Text="Secili model tablolarinda UDP bulunamadi."
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#6B7280"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
