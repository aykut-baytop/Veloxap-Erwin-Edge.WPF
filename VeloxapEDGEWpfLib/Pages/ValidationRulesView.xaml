<UserControl x:Class="VeloxapEDGEWpfLib.Pages.ValidationRulesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:VeloxapEDGEWpfLib.Pages"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <Style x:Key="WrappedCellTextStyle" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Validasyon Kuralları"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="#111827"/>

            <TextBlock Text="Tanımlı kurallar"
                       Margin="0,6,0,0"
                       Foreground="#6B7280"
                       FontSize="13"/>
        </StackPanel>

        <Border Grid.Row="2"
                Background="#F9FAFB"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                CornerRadius="12"
                Padding="12">
            <DockPanel>
                <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                    <TextBlock Text="Kural Listesi"
                               FontWeight="SemiBold"
                               FontSize="14"
                               Foreground="#374151"/>

                    <TextBlock x:Name="txtRuleCount"
                               HorizontalAlignment="Right"
                               Foreground="#6B7280"
                               FontSize="12"/>
                </Grid>

                

                <Grid>
                    <DataGrid x:Name="dgValidationRules"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="None"
                              ColumnHeaderHeight="38"
                              BorderThickness="0"
                              Background="White"
                              AlternatingRowBackground="#F3F4F6">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Id"
                                                Binding="{Binding Id}"
                                                Width="70"/>

                            <DataGridTextColumn Header="Kural Adı"
                                                Binding="{Binding RuleName}"
                                                Width="170"
                                                ElementStyle="{StaticResource WrappedCellTextStyle}"/>

                            <DataGridTextColumn Header="Kural Tanımı"
                                                Binding="{Binding RuleDefinition}"
                                                Width="2*"
                                                ElementStyle="{StaticResource WrappedCellTextStyle}"/>

                            <DataGridTextColumn Header="Kural"
                                                Binding="{Binding RuleText}"
                                                Width="3*"
                                                ElementStyle="{StaticResource WrappedCellTextStyle}"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border x:Name="emptyState"
                            Background="#F9FAFB"
                            Visibility="Collapsed">
                        <TextBlock x:Name="emptyStateText"
                                   Text="Tanımlı validasyon kuralı bulunamadı."
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="#6B7280"
                                   FontSize="13"/>
                    </Border>
                </Grid>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
