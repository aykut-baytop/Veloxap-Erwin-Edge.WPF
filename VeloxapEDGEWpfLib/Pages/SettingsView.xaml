<UserControl x:Class="VeloxapEDGEWpfLib.Pages.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:VeloxapEDGEWpfLib.Pages"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <Style x:Key="WrappedCellTextStyle" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="84"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Background" Value="#D1D5DB"/>
                                <Setter Property="Foreground" Value="#6B7280"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsDataGridStyle" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="False"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="RowHeight" Value="42"/>
            <Setter Property="ColumnHeaderHeight" Value="38"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F3F4F6"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Ayarlar"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="#111827"/>

            <TextBlock x:Name="txtConfigSource"
                       Margin="0,6,0,0"
                       Foreground="#6B7280"
                       FontSize="13"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <Border Grid.Row="2"
                Background="#F9FAFB"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                CornerRadius="12"
                Padding="12">
            <DockPanel>
                <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="App.config Ayarları"
                               FontWeight="SemiBold"
                               FontSize="14"
                               Foreground="#374151"/>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal">
                        <TextBlock x:Name="txtSettingCount"
                                   VerticalAlignment="Center"
                                   Foreground="#6B7280"
                                   FontSize="12"/>

                        <Button Content="Yenile"
                                Style="{StaticResource ActionButtonStyle}"
                                Background="#4B5563"
                                Click="BtnReload_Click"/>

                        <Button Content="Kaydet"
                                Style="{StaticResource ActionButtonStyle}"
                                Click="BtnSave_Click"/>
                    </StackPanel>
                </Grid>

                <TextBlock x:Name="txtSaveStatus"
                           DockPanel.Dock="Bottom"
                           Margin="0,10,0,0"
                           Foreground="#059669"
                           FontSize="12"/>

                <Grid>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Kullanıcı Bilgileri"
                                           FontWeight="SemiBold"
                                           Foreground="#374151"
                                           FontSize="13" Background="{DynamicResource {x:Static SystemColors.ActiveCaptionBrushKey}}"/>

                                <TextBlock x:Name="txtUserSettingCount"
                                           Grid.Column="1"
                                           Foreground="#6B7280"
                                           FontSize="12"/>
                            </Grid>

                            <DataGrid x:Name="dgUserSettings"
                                      Style="{StaticResource SettingsDataGridStyle}"
                                      MaxHeight="132">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Anahtar"
                                                        Binding="{Binding Key}"
                                                        IsReadOnly="True"
                                                        Width="240"
                                                        ElementStyle="{StaticResource WrappedCellTextStyle}"/>

                                    <DataGridTextColumn Header="Değer"
                                                        Binding="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        Width="*"
                                                        ElementStyle="{StaticResource WrappedCellTextStyle}"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <Grid Margin="0,16,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Servis Bilgileri"
                                           FontWeight="SemiBold"
                                           Foreground="#374151"
                                           FontSize="13" Background="{DynamicResource {x:Static SystemColors.ActiveCaptionBrushKey}}"/>

                                <TextBlock x:Name="txtServiceSettingCount"
                                           Grid.Column="1"
                                           Foreground="#6B7280"
                                           FontSize="12"/>
                            </Grid>

                            <DataGrid x:Name="dgServiceSettings"
                                      Style="{StaticResource SettingsDataGridStyle}"
                                      MaxHeight="240">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Anahtar"
                                                        Binding="{Binding Key}"
                                                        IsReadOnly="True"
                                                        Width="240"
                                                        ElementStyle="{StaticResource WrappedCellTextStyle}"/>

                                    <DataGridTextColumn Header="Değer"
                                                        Binding="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        Width="*"
                                                        ElementStyle="{StaticResource WrappedCellTextStyle}"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </ScrollViewer>

                    <Border x:Name="emptyState"
                            Background="#F9FAFB"
                            Visibility="Collapsed">
                        <TextBlock Text="App.config içinde appSettings ayarı bulunamadı."
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="#6B7280"
                                   FontSize="13"/>
                    </Border>
                </Grid>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
